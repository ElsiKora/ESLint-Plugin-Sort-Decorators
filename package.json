{
	"name": "@elsikora/eslint-plugin-sort-decorators",
	"version": "0.2.8",
	"description": "An ESLint plugin to sort decorators",
	"keywords": [
		"eslint",
		"eslintplugin",
		"decorators",
		"sort",
		"plugin"
	],
	"homepage": "https://github.com/ElsiKora/ESLint-Plugin-Sort-Decorators",
	"bugs": {
		"url": "https://github.com/ElsiKora/ESLint-Plugin-Sort-Decorators/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ElsiKora/ESLint-Plugin-Sort-Decorators.git"
	},
	"license": "MIT",
	"author": "ElsiKora",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/esm/index.d.ts",
			"import": "./dist/esm/index.js",
			"require": "./dist/cjs/index.js"
		}
	},
	"main": "./dist/cjs/index.js",
	"module": "./dist/esm/index.js",
	"types": "./dist/esm/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"branch": "npx @elsikora/git-branch-lint -b",
		"prebuild": "rimraf dist",
		"build": "rollup -c",
		"build:test": "npm run prebuild && rollup -c rollup.test.config.js",
		"commit": "cz",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"lint": "eslint .",
		"lint:all": "npm run lint && npm run lint:types",
		"lint:all:fix": "npm run lint:fix && npm run lint:types:fix",
		"lint:fix": "eslint --fix .",
		"lint:types": "tsc --noEmit --project tsconfig.build.json",
		"lint:types:fix": "tsc --noEmit --skipLibCheck",
		"prepare": "husky",
		"release": "semantic-release",
		"test": "npm run test:unit",
		"test:all": "npm run test:unit",
		"test:coverage": "vitest run --config vitest.unit.config.js --coverage",
		"test:unit": "vitest run --config vitest.unit.config.js",
		"typecheck": "npm run lint:types",
		"validate": "npm run lint:all && npm run test:unit && npm run build",
		"validate:fast": "npm run lint && npm run lint:types && npm run test:unit",
		"validate:package": "npm run build",
		"validate:pr": "npm run validate:fast && npm run validate:package"
	},
	"config": {
		"commitizen": {
			"path": "@elsikora/commitizen-plugin-commitlint-ai"
		}
	},
	"dependencies": {
		"@typescript-eslint/utils": "^8.59.4"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"@elsikora/commitizen-plugin-commitlint-ai": "^3.0.1",
		"@elsikora/eslint-config": "3.7.13",
		"@elsikora/git-branch-lint": "^1.2.2",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^9.39.2",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"@saithodev/semantic-release-backmerge": "^4.0.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.8",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/eslint": "^9.6.1",
		"@types/eslint__js": "^8.42.3",
		"@types/node": "^25.9.1",
		"@typescript-eslint/eslint-plugin": "^8.59.4",
		"@typescript-eslint/parser": "^8.59.4",
		"@typescript-eslint/rule-tester": "^8.59.4",
		"@vitest/coverage-v8": "^4.1.6",
		"commitizen": "^4.3.1",
		"conventional-changelog-conventionalcommits": "^9.3.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-check-file": "^3.3.1",
		"eslint-plugin-jsonc": "^2.21.0",
		"eslint-plugin-n": "^17.24.0",
		"eslint-plugin-no-secrets": "^2.2.2",
		"eslint-plugin-package-json": "^1.1.0",
		"eslint-plugin-perfectionist": "^4.15.1",
		"eslint-plugin-prettier": "^5.5.4",
		"eslint-plugin-regexp": "^2.10.0",
		"eslint-plugin-sonarjs": "^3.0.5",
		"eslint-plugin-tailwindcss": "^3.18.2",
		"eslint-plugin-unicorn": "^64.0.0",
		"eslint-plugin-yml": "^1.19.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"rollup": "^4.60.4",
		"rollup-plugin-dts-path-alias": "^0.0.3",
		"rollup-plugin-generate-package-json": "^3.2.0",
		"semantic-release": "^25.0.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.6"
	},
	"peerDependencies": {
		"@typescript-eslint/parser": ">=8.0.0",
		"eslint": ">=9.18.0"
	},
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public"
	}
}
